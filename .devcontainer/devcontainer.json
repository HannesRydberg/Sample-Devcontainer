// .devcontainer/devcontainer.json
{
    "name": "DevContainer (AI + DinD)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    // ======================== Features ========================
    "features": {
        // Docker-in-Docker — full isolated dockerd (rootless disabled: uses standard
        // root dockerd + socket group access, avoiding slirp4netns network slowness).
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "moby": true,
            "version": "latest",
            "enableNonRootDocker": false,
            "installDockerBuildx": true,
            "dockerDashComposeVersion": "v2"
        },
        // Node.js 24 — required by Copilot CLI
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24"
        },
        // Language runtimes
        "ghcr.io/devcontainers/features/dotnet:2": { "version": "latest" },
        "ghcr.io/devcontainers/features/python:1": { "version": "latest" },
        "ghcr.io/devcontainers/features/go:1": { "version": "latest" },
        "ghcr.io/devcontainers/features/java:1": { "version": "latest" },
        // GitHub Copilot CLI — official devcontainers feature
        "ghcr.io/devcontainers/features/copilot-cli:1": {}
    },
    // Node.js must install before Copilot CLI (npm-based).
    // Language runtimes before Node so PATH ordering is consistent.
    // DinD last — it hooks the container entrypoint to start dockerd.
    "overrideFeatureInstallOrder": [
        "ghcr.io/devcontainers/features/dotnet",
        "ghcr.io/devcontainers/features/python",
        "ghcr.io/devcontainers/features/go",
        "ghcr.io/devcontainers/features/java",
        "ghcr.io/devcontainers/features/node",
        "ghcr.io/devcontainers/features/copilot-cli",
        "ghcr.io/devcontainers/features/docker-in-docker"
    ],
    // ======================== Filesystem Isolation ========================
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "workspaceFolder": "/workspace",
    "mounts": [
        // Named volume for NuGet cache — persists across rebuilds
        {
            "source": "devcontainer-nuget-${devcontainerId}",
            "target": "/home/vscode/.nuget",
            "type": "volume"
        },
        // Named volume for all Copilot data — keeps session DB, WAL files, logs, and
        // command history off the macOS bind-mount layer (VirtioFS fsync is very slow).
        // Skills are overlaid below via a targeted bind mount so host edits are live.
        // ⚠️  Auth state is container-local: run `copilot auth login` after first rebuild.
        {
            "source": "devcontainer-copilot-data-${devcontainerId}",
            "target": "/home/vscode/.copilot",
            "type": "volume"
        },
        // Bind-mount just ~/.copilot/skills so adding/editing skills on the host is
        // immediately reflected inside the container without a rebuild.
        // Run once on your Mac before first open:
        //   mkdir -p ~/.copilot/skills ~/.agents/skills ~/.config/copilot-dev-skills
        {
            "source": "${localEnv:HOME}/.copilot/skills",
            "target": "/home/vscode/.copilot/skills",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.agents/skills",
            "target": "/home/vscode/.agents/skills",
            "type": "bind"
        },
        // Per-developer skill sets for this repo. Organised as subdirectories under
        // ~/.config/copilot-dev-skills/ on the host. List which sets to load in the
        // git-ignored .copilot-skills file at the repo root.
        // One-time host setup: mkdir -p ~/.config/copilot-dev-skills
        {
            "source": "${localEnv:HOME}/.config/copilot-dev-skills",
            "target": "/home/vscode/.config/copilot-dev-skills",
            "type": "bind"
        },
        // Secrets file — bind-mounted read-only so postCreate.sh can source it into
        // every terminal session without ever passing secrets as Docker env vars.
        // Stored outside the repo (~/.config/dev/dev.env) so it is never committed.
        // One-time host setup: mkdir -p ~/.config/dev && cp .env.example ~/.config/dev/dev.env
        {
            "source": "${localEnv:HOME}/.config/dev/dev.env",
            "target": "/run/secrets/dev.env",
            "type": "bind"
        }
    ],
    // ======================== Runtime ========================
    // Secrets are NOT passed as Docker env vars — doing so stores them in the container
    // config and makes them visible via `docker inspect` / Docker Desktop Inspect tab.
    // Instead, /run/secrets/dev.env is bind-mounted read-only and sourced by postCreate.sh.
    "init": true,
    "remoteUser": "vscode",
    "containerEnv": {
        "DOTNET_NOLOGO": "true",
        "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    },
    // ======================== VS Code Extensions ========================
    "customizations": {
        "vscode": {
            "extensions": [
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-dotnettools.csdevkit",
                "ms-dotnettools.csharp",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    // ======================== Lifecycle ========================
    "postCreateCommand": "bash .devcontainer/postCreate.sh",
    // ======================== Port Forwarding ========================
    // runArgs publishes the port to the host at the Docker level — works regardless of IDE.
    // forwardPorts is kept for VS Code's port forwarding panel / automatic browser open.
    // --dns 8.8.8.8: bypasses Docker Desktop's slow internal DNS resolver on macOS.
    "runArgs": ["-p", "5300:5300", "-p", "5301:5301", "-p", "5302:5302", "--dns", "8.8.8.8"],
    "forwardPorts": [5300, 5301, 5302],
    // ======================== Host Requirements ========================
    // Universal image is large (~10 GB); allocate accordingly.
    "hostRequirements": {
        "cpus": 4,
        "memory": "8gb",
        "storage": "32gb"
    }
}
