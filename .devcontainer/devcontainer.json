{
  "name": "Ubuntu DevContainer (Copilot + DinD)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  // ======================== Features ========================
  "features": {
    // Docker-in-Docker — full isolated dockerd.
    // "moby": true is REQUIRED to avoid TestContainers .NET NullReferenceException.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "version": "latest",
      "enableNonRootDocker": true,
      "installDockerBuildx": true,
      "dockerDashComposeVersion": "v2",
      // Pin the inner dockerd's bridge/network pool OFF the host bridge range
      // (172.17.0.0/16). Without this, a startup race lets the inner docker0
      // grab 172.17.0.1 — the SAME IP as the container's default gateway — so
      // the kernel treats the gateway as a local address and ~50% of new
      // outbound connections black-hole to loopback (5s+ stalls, intermittent
      // per container). 172.20.0.0/16 cannot collide with the host bridge.
      "dockerDefaultAddressPool": "base=172.20.0.0/16,size=24"
    },
    // Node.js — required runtime for Copilot CLI
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    // Language runtimes
    "ghcr.io/devcontainers/features/dotnet:2": { "version": "latest" },
    "ghcr.io/devcontainers/features/python:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/go:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/java:1": { "version": "latest" },
    // GitHub Copilot CLI — official devcontainers feature
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },
  // Node.js must install before Copilot CLI (npm-based).
  // DinD last — it hooks the container entrypoint to start dockerd.
  "overrideFeatureInstallOrder": [
    "ghcr.io/devcontainers/features/dotnet",
    "ghcr.io/devcontainers/features/python",
    "ghcr.io/devcontainers/features/go",
    "ghcr.io/devcontainers/features/java",
    "ghcr.io/devcontainers/features/node",
    "ghcr.io/devcontainers/features/copilot-cli",
    "ghcr.io/devcontainers/features/docker-in-docker"
  ],
  // ======================== Filesystem Isolation ========================
  // Use a stable workspace path so feature postStart hooks don't fail on first start
  // if /workspaces/<repo-name> is not present yet.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "mounts": [
    // ── NuGet: shared host cache only ──
    "source=${localEnv:HOME}/.nuget/packages,target=/home/vscode/.nuget/packages,type=bind,consistency=cached",
     // ── Copilot: shared host skills and agents only ──
    // Keep the rest of ~/.copilot container-local so auth, session data,
    // logs, settings, and instructions do not leak between host and container.
    "source=${localEnv:HOME}/.copilot/skills,target=/home/vscode/.copilot/skills,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.copilot/agents,target=/home/vscode/.copilot/agents,type=bind,consistency=cached",
    // Secrets file — bind-mounted read-only so postCreate.sh can source it
    // without ever passing secrets as Docker env vars (-e flags).
    "type=bind,source=${localEnv:HOME}/.config/dev/dev.env,target=/run/secrets/dev.env,readonly"
  ],
  // ======================== Runtime ========================
  // Secrets are NOT passed as Docker env vars — doing so stores them in the container
  // config and makes them visible via `docker inspect` / Docker Desktop Inspect tab.
  // Instead, ~/.config/dev/dev.env is bind-mounted read-only to /run/secrets/dev.env and processed by postCreate.sh.
  "init": true,
  "initializeCommand": "node .devcontainer/initialize-host-paths.mjs",
  "remoteUser": "vscode",
  "containerEnv": {
    "DOTNET_NOLOGO": "true",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "NUGET_PACKAGES": "/home/vscode/.nuget/packages"
  },

  // runArgs publishes the port to the host at the Docker level — works regardless of IDE.
  // forwardPorts is kept for VS Code's port forwarding panel / automatic browser open.
  "runArgs": [
    "-p",
    "6300:6300",
    "-p",
    "6301:6301",
    "-p",
    "6302:6302"
  ],
  "forwardPorts": [6300, 6301, 6302],
  // ======================== Lifecycle ========================
  "postCreateCommand": "sed 's/\\r$//' .devcontainer/postCreate.sh | bash",
  // ======================== Host Requirements ========================
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  }
}
