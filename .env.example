# Developer secrets template — copy this file to ~/.config/dev/dev.env and fill in real values.
# This file stays in git as an example only. Your real secrets file lives outside the repo.
#
#   mkdir -p ~/.config/dev
#   cp .env.example ~/.config/dev/dev.env
#   # then edit ~/.config/dev/dev.env with your actual tokens

COPILOT_GITHUB_TOKEN="github_pat_..."

## For GitHub Enterprise, set the host URL (for example "https://mycompany.ghe.com").
## For public github.com, leave this blank or set it to "https://github.com".
##COPILOT_GH_HOST=""
